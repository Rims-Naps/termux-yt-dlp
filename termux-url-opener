#!/bin/bash
clear
url=$1

# Check if the URL contains "YouTube" or "youTube"
if [[ $url == *"YouTube"* ]] || [[ $url == *"youTube"* ]]; then
    # Download audio in MP3 format
    yt-dlp -x --audio-format mp3 -f bestaudio --audio-quality 0 "$url" -o "/data/data/com.termux/files/home/storage/downloads/%(title)s.%(ext)s"
else
    # Download video in MP4 format
    yt-dlp -f 'bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best' "$url" -o "/data/data/com.termux/files/home/storage/downloads/%(title)s.%(ext)s"
fi
