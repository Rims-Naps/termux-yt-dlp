#!/bin/bash

# Define output templates for organized downloads
PLAYLIST="%(extractor)s/playlists/%(playlist_title)s_%(playlist_id)s/%(playlist_index)03d - %(uploader)s_%(channel_id)s - %(title)s [%(id)s].%(ext)s"
CHANNEL="%(extractor)s/%(uploader)s_%(channel_id)s/%(title)s [%(id)s].%(ext)s"
VIDEO="%(extractor)s/%(title)s [%(id)s].%(ext)s"

# Function to download the URL using yt-dlp
download() {
    local url="$1"

    # Check if the URL is a YouTube link
    if [[ "$url" =~ .*youtu.* ]] || [[ "$url" =~ .*youtube.* ]]; then
        echo -e "YouTube link detected: $url"

        # Detect if it's a playlist
        if [[ "$url" =~ .*/playlist.* ]] || [[ "$url" =~ .*list=.* ]]; then
            echo "Downloading as a playlist..."
            yt-dlp -o "$PLAYLIST" "$url"
        elif [[ "$url" =~ .*/channel.* ]] || [[ "$url" =~ .*channel.* ]]; then
            echo "Downloading as a channel..."
            yt-dlp -o "$CHANNEL" "$url"
        else
            echo "Downloading as a single video..."
            yt-dlp -f "bestaudio[ext=m4a]" --extract-audio --audio-format m4a -o "$VIDEO" "$url"
        fi
    else
        echo "Non-YouTube link detected: $url"
        echo "Downloading best quality video..."
        yt-dlp -f "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best" -o "$VIDEO" "$url"
    fi
}

# Main entry point - the URL passed to the script is in "$1"
if [[ -z "$1" ]]; then
    echo "No URL provided. Exiting."
    exit 1
fi

# Call the download function with the URL
download "$1"
