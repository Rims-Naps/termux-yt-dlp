#!/bin/bash

# Function to download audio or video
download() {
    local url=$1
    local format=$2
    local playlist=$3

    if [[ $playlist == "yes" ]]; then
        yt-dlp -f "$format" --yes-playlist "$url"
    else
        yt-dlp -f "$format" --no-playlist "$url"
    fi
}

# Prompt user for download options
echo "Download options (please enter 1 or 2):"
echo "1. No playlist download"
echo "2. Yes playlist download"
read -p "Enter your choice: " choice

if [[ $choice -eq 1 ]]; then
    playlist="no"
elif [[ $choice -eq 2 ]]; then
    playlist="yes"
else
    echo "Invalid choice. Exiting."
    exit 1
fi

# Check if the URL contains "youtube" or "YouTube"
if [[ $1 == *"youtube"* || $1 == *"YouTube"* ]]; then
    echo "YouTube link detected. Downloading audio in best quality (m4a)."
    download "$1" "bestaudio[ext=m4a]" "$playlist"
else
    echo "Non-YouTube link detected. Downloading video in best quality (mp4)."
    download "$1" "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best" "$playlist"
fi
