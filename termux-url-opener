#!/bin/bash

# Function to download audio or video
download() {
    local url=$1
    local format=$2
    local playlist=$3
    local output_dir="/storage/emulated/0/Download"  # Path to shared storage

    if [[ $playlist == "yes" ]]; then
        yt-dlp -o "$output_dir/%(title)s.%(ext)s" -f "$format" --yes-playlist "$url"
    else
        yt-dlp -o "$output_dir/%(title)s.%(ext)s" -f "$format" --no-playlist "$url"
    fi
}

# Check if the URL contains "youtube" or "YouTube"
if [[ $1 == *"youtube"* || $1 == *"YouTube"* ]]; then
    echo "YouTube link detected. Checking if it's a playlist."
    
    # Detect if the URL is a playlist
    if [[ $1 == *"list="* ]]; then
        echo "Playlist detected. Downloading audio in best quality (m4a)."
        download "$1" "bestaudio[ext=m4a]" "yes"
    else
        echo "Single video detected. Downloading audio in best quality (m4a)."
        download "$1" "bestaudio[ext=m4a]" "no"
    fi
else
    echo "Non-YouTube link detected. Checking if it's a playlist."
    
    # Detect if the URL is a playlist
    if [[ $1 == *"list="* ]]; then
        echo "Playlist detected. Downloading video in best quality (mp4)."
        download "$1" "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best" "yes"
    else
        echo "Single video detected. Downloading video in best quality (mp4)."
        download "$1" "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best" "no"
    fi
fi
