#!/bin/bash
clear
url=$1

# Function to ensure downloaded videos are compatible with Android
download_compatible_video() {
    # Force mp4 container with h264 video codec and aac audio codec
    # These are widely supported by Android devices
    yt-dlp -f "bestvideo[ext=mp4][vcodec^=avc1]+bestaudio[ext=m4a]/best[ext=mp4]" \
        --merge-output-format mp4 \
        --prefer-ffmpeg \
        --postprocessor-args "-codec:v libx264 -codec:a aac" \
        "$1" \
        -o "/data/data/com.termux/files/home/storage/downloads/%(title)s.%(ext)s"
}

# Function to download audio only
download_audio() {
    yt-dlp -x \
        --audio-format mp3 \
        --audio-quality 0 \
        --prefer-ffmpeg \
        "$1" \
        -o "/data/data/com.termux/files/home/storage/downloads/%(title)s.%(ext)s"
}

# Check if the URL contains "YouTube" or "youTube"
if [[ $url == *"YouTube"* ]] || [[ $url == *"youTube"* ]]; then
    echo "Downloading audio from YouTube..."
    download_audio "$url"
else
    echo "Downloading video..."
    download_compatible_video "$url"
fi

echo "Download complete!"
