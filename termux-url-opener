#!/bin/bash
# termux-url-opener script to download YouTube videos or playlists automatically

# Output templates for playlists and channels
PLAYLIST_OUTPUT="%(extractor)s/playlists/%(playlist_title)s_%(playlist_id)s/%(n_entries-playlist_index)03d - %(uploader)s_%(channel_id)s - %(title)s [%(id)s].%(ext)s"
CHANNEL_OUTPUT="%(extractor)s/%(uploader)s_%(channel_id)s/%(title)s [%(id)s].%(ext)s"

# Check if a valid URL is provided
if [[ -z "$1" ]]; then
    echo "Error: No URL provided. Please pass a valid URL to the script."
    exit 1
fi

# Detect YouTube links
if [[ "$1" =~ ^.*youtu(be)?.* ]]; then
    echo "YouTube link detected. Processing..."
    
    # Automatically detect if it's a playlist or single video
    if [[ "$1" =~ .*/playlist.* ]] || [[ "$1" =~ .*list=.* ]]; then
        OUTPUT_TEMPLATE="$PLAYLIST_OUTPUT"
        echo "Playlist detected. Using playlist-specific output template."
    else
        OUTPUT_TEMPLATE="$CHANNEL_OUTPUT"
        echo "Single video detected. Using channel-specific output template."
    fi

    # Download using yt-dlp
    yt-dlp -o "$OUTPUT_TEMPLATE" "$1"

else
    # Non-YouTube links: Default to best video and audio quality
    echo "Non-YouTube link detected. Downloading in best video/audio quality..."
    yt-dlp -f 'bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best' "$1"
fi
